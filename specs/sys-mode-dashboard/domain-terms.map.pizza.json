{
  "_about": "PIZZA-BUSINESS test mapping. Filled-in copy of `domain-terms.map.json` so you can exercise scripts/swap-domain-terms.js against a fully-populated map. Domain story: a pizza chain dashboard managing two branches (Downtown / Uptown), each with 4 ovens; a manager fires Orders at a Branch + Oven, and a real-time grid shows pizza-prep + delivery + hotline status.",
  "_match": {
    "identifiers": "Match as TypeScript symbols only (\\b<id>\\b). Affects .ts/.html/.scss spec ids.",
    "strings": "Match as exact string literals (quoted or unquoted in HTML text nodes). Case-sensitive.",
    "css": "CSS class fragments — match inside .scss selectors AND .html class= attributes."
  },

  "feature": {
    "_kind": "identifiers + strings + css",
    "_note": "The product/feature name itself.",
    "system-experiments": { "to": "pizza-dashboard" },
    "SystemExperiments":  { "to": "PizzaDashboard" },
    "systemExperiments":  { "to": "pizzaDashboard" },
    "SYSTEM_EXPERIMENTS":  { "to": "PIZZA_DASHBOARD" }
  },

  "shellChrome": {
    "_kind": "strings",
    "Sys Mode":           { "to": "Service" },
    "Active":             { "to": "Open" },
    "Not Active":         { "to": "Closed" },
    "System Commands":    { "to": "Order Tickets" },
    "Failure & Antenna":  { "to": "Alerts & Hotline" }
  },

  "cmdConcept": {
    "_kind": "identifiers + strings",
    "Cmd":   { "to": "Order", "_kind": "string" },
    "Cmd to GS": { "to": "Notes to Kitchen", "_kind": "string" },
    "cmd":   { "to": "order", "_kind": "identifier" },
    "cmd-side-select":  { "to": "order-branch-select", "_kind": "string" },
    "cmd-wheel-select": { "to": "order-oven-select", "_kind": "string" },
    "CmdSelection":     { "to": "OrderSelection", "_kind": "identifier" },
    "CmdSectionComponent": { "to": "OrderSectionComponent", "_kind": "identifier" }
  },

  "sideAndWheel": {
    "_kind": "identifiers + strings",
    "_note": "Physical platform → pizza branches (left/right of city) and ovens (1-4).",
    "Side":  { "to": "Branch",   "_kind": "identifier" },
    "SIDE":  { "to": "BRANCH",   "_kind": "identifier" },
    "side":  { "to": "branch",   "_kind": "identifier" },
    "sides": { "to": "branches", "_kind": "identifier" },
    "Wheel": { "to": "Oven",     "_kind": "identifier" },
    "WHEEL": { "to": "OVEN",     "_kind": "identifier" },
    "wheel":  { "to": "oven",    "_kind": "identifier" },
    "wheels": { "to": "ovens",   "_kind": "identifier" },
    "Left":  { "to": "Downtown", "_kind": "string" },
    "Right": { "to": "Uptown",   "_kind": "string" },
    "left":  { "to": "downtown", "_kind": "string" },
    "right": { "to": "uptown",   "_kind": "string" }
  },

  "gridColumns": {
    "_kind": "identifiers + strings",
