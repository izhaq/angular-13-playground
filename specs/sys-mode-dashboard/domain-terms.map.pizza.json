  "_known_overlaps": {
    "_about": "These source strings appear in two contexts in the original; a single global swap will replace both. For a real-domain rename you'd usually de-duplicate the source labels first — for this pizza test it's fine.",
    "Not Active": "shell `Sys Mode` chip + TFF cheese.None label → both become 'Closed'",
    "Mtr Rec":    "field label is shared between `mtrRec` and `gsMtrRec` → both become 'Print Receipt' (gsMtrRec key still renames to `managerReceipt`)",
    "FRC":        "abbr shared between Primary Force-TTL and Secondary Normal/Forced → both become 'RSH'"
  }
