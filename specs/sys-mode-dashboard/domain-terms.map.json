{
  "_about": "Domain-specific names used in the system-experiments feature (client-only). Generic terms (PRIMARY_COMMANDS, board, footer, status-grid, Yes/No/On/Off, Apply/Cancel/Defaults, etc.) are intentionally excluded. To swap to a different domain, fill in `to` for any term you want renamed and run your replacement script. Match strategy: identifiers should be matched with word-boundary regex (\\b<id>\\b); strings should be matched exactly (case-sensitive).",
  "_match": {
    "identifiers": "Match as TypeScript symbols only (\\b<id>\\b). Affects .ts/.html/.scss spec ids.",
    "strings": "Match as exact string literals (quoted or unquoted in HTML text nodes). Case-sensitive.",
    "css": "CSS class fragments — match inside .scss selectors AND .html class= attributes."
  },

